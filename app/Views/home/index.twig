{% extends "layout.twig" %}

{% block content %}
<div class="p-5 mb-4 bg-light rounded-3">
    <div class="container-fluid py-5">
      <h1 class="display-5 fw-bold">{{ title }}</h1>
      <p class="col-md-8 fs-4">Welcome to the Mini MVC Framework. This is a simple demonstration of using Twig and Eloquent.</p>
    </div>
</div>

<h2>Recent Users</h2>
<ul class="list-group">
{% for user in users %}
    <li class="list-group-item">{{ user.name }} - {{ user.email }}</li>
{% else %}
    <li class="list-group-item text-muted">No users found. Run migration and seed data.</li>
{% endfor %}
</ul>
{% endblock %}
